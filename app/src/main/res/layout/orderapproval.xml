<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:ripple="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="5dp"
    card_view:cardCornerRadius="5dp"
    card_view:cardElevation="4dp"
    card_view:cardPreventCornerOverlap="false"
    card_view:cardUseCompatPadding="true">

    <RelativeLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">

        <RelativeLayout
            android:id="@+id/r1"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/itemtet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"
                android:layout_marginLeft="15dp"
                android:layout_marginTop="5dp"
                android:text="Order No."
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="@android:color/black"
                android:typeface="monospace" />

            <ImageView
                android:id="@+id/imageView1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_alignParentRight="true"
                android:layout_marginTop="3dp"
                android:layout_marginRight="3dp"
                android:src="@drawable/absracticon" />

            <TextView
                android:id="@+id/orderdate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignBottom="@+id/itemtet"
                android:layout_marginRight="5dp"
                android:layout_toLeftOf="@+id/imageView1"
                android:text="12 july 1990 3.21pm"
                android:textSize="11.5dp"
                android:typeface="monospace" />

        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/r2"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/r1">

            <TextView
                android:id="@+id/orderno"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:layout_marginTop="2dp"
                android:text="423635745345"
                android:textColor="@color/colorPrimary"
                android:textSize="11dp"
                android:textStyle="bold"
                android:typeface="monospace" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/r3"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/r2"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/textView3"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_marginLeft="15dp"
                android:text="Medium Text"
                android:textColor="@android:color/black"
                android:textSize="15dp"
                android:typeface="monospace" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/r4"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/r3">

            <LinearLayout
                android:id="@+id/l1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_toLeftOf="@+id/l2">

                <TextView
                    android:id="@+id/textView6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:layout_marginTop="2dp"
                    android:text="Sale By: "
                    android:textColor="@android:color/black"
                    android:textSize="10dp"
                    android:typeface="monospace" />

                <TextView
                    android:id="@+id/txtsale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Small Text"
                    android:textSize="11dp"
                    android:typeface="monospace" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/l2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_alignParentRight="true"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="10dp">

                <TextView
                    android:id="@+id/textView5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Crdays : "
                    android:textColor="@android:color/black"
                    android:textSize="10dp"
                    android:typeface="monospace" />

                <TextView
                    android:id="@+id/cr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:layout_marginTop="2dp"
                    android:text="Small Text"
                    android:textSize="11dp"
                    android:typeface="monospace" />
            </LinearLayout>
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/r5"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/r4"
            android:layout_marginTop="2dp">

            <LinearLayout
                android:id="@+id/l3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"
                android:layout_toLeftOf="@+id/l4"
                android:weightSum="1">

                <TextView
                    android:id="@+id/txtitu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:layout_marginTop="2dp"
                    android:text="Broker : "
                    android:textColor="@android:color/black"
                    android:textSize="10dp"
                    android:typeface="monospace" />

                <TextView
                    android:id="@+id/txtbroker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Small Text"
                    android:textSize="11dp"
                    android:typeface="monospace" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/l4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_alignParentRight="true"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="10dp"
                android:weightSum="1">

                <TextView
                    android:id="@+id/qtytet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Quantity : "
                    android:textColor="@android:color/black"
                    android:textSize="10dp"
                    android:typeface="monospace" />

                <TextView
                    android:id="@+id/txtqty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:layout_marginTop="2dp"
                    android:text="TextView"
                    android:textSize="11dp"
                    android:typeface="monospace" />
            </LinearLayout>
        </RelativeLayout>


        <RelativeLayout
            android:id="@+id/r6"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/r5"
            android:layout_marginTop="2dp">

            <LinearLayout
                android:id="@+id/l5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"
                android:weightSum="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:layout_marginTop="2dp"
                    android:text="Reason : "
                    android:textColor="@android:color/holo_red_dark"
                    android:textSize="10dp"
                    android:typeface="monospace" />

                <TextView
                    android:id="@+id/txtres"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Small Text"
                    android:textSize="11dp"
                    android:typeface="monospace" />
            </LinearLayout>


        </RelativeLayout>


        <RelativeLayout
            android:id="@+id/r7"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/r6"
            android:layout_marginTop="2dp">

            <LinearLayout
                android:id="@+id/l6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"
                android:weightSum="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:layout_marginTop="2dp"
                    android:text="Remark : "
                    android:textColor="@android:color/holo_red_dark"
                    android:textSize="10dp"
                    android:typeface="monospace" />

                <TextView
                    android:id="@+id/txtrmt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Small Text"
                    android:textSize="11dp"
                    android:typeface="monospace" />
            </LinearLayout>


        </RelativeLayout>

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/r7"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">


            <Button
                android:id="@+id/appro"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:background="#d2d2d2"
                android:layout_weight="1"
                android:textColor="@color/colorPrimary"
                android:layout_margin="2dp"
                android:text="APPROVAL" />

            <Button
                android:id="@+id/unapp"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_toRightOf="@+id/appro"
                android:background="#e2e2e2"
                android:layout_weight="1"
                android:textColor="@color/colorPrimary"
                android:layout_margin="2dp"
                android:text="UNAPPROVED" />

            <TextView
                android:id="@+id/txtitu2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:layout_marginTop="2dp"
                android:text="Item : "
                android:textColor="@android:color/black"
                android:textSize="10dp"
                android:typeface="monospace"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txtitemnam"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toRightOf="@+id/txtitu2"
                android:text="Small Text"
                android:textSize="11dp"
                android:typeface="monospace"
                android:visibility="gone" />
        </LinearLayout>
    </RelativeLayout>

</androidx.cardview.widget.CardView>